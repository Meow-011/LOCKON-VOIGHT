# LOCKON VOIGHT — Production Environment Variables
# Copy to .env and set REAL values before deploying!

# Database
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# JWT — MANDATORY: Server will refuse to start without this!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Domain (for CORS and SSL)
DOMAIN=voight.example.com
