# LOCKON VOIGHT — Environment Variables
# Copy this to .env and adjust values

# Application
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://voight:voight_secret@localhost:5432/voight_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (CHANGE THIS IN PRODUCTION!)
JWT_SECRET_KEY=voight-dev-secret-change-in-production

# gRPC
GRPC_PORT=50051

# Agent Configuration
AGENT_HEARTBEAT_INTERVAL_SECONDS=10
AGENT_HEARTBEAT_TIMEOUT_SECONDS=30

# Scoring Thresholds
SCORE_THRESHOLD_GREEN=30
SCORE_THRESHOLD_YELLOW=70

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Data Retention (days)
DATA_RETENTION_DAYS=30
